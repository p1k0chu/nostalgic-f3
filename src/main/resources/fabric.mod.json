{
  "schemaVersion": 1,
  "id": "bettervanillaf3",
  "version": "${version}",
  "name": "Better Vanilla F3",
  "description": "Fixes and consistency for 1.21.9+ debug overlay",
  "authors": [
    "p1k0chu"
  ],
  "contact": {
    "homepage": "https://github.com/p1k0chu/bettervanillaf3",
    "sources": "https://github.com/p1k0chu/bettervanillaf3"
  },
  "icon": "assets/bettervanillaf3/icon.png",
  "license": "LGPL-3.0-or-later",
  "environment": "*",
  "entrypoints": {
    "client": [
      "io.github.p1k0chu.bettervanillaf3.client.BetterVanillaF3Client"
    ],
    "modmenu": [
      "io.github.p1k0chu.bettervanillaf3.client.BetterVanillaF3ModMenuIntegration"
    ]
  },
  "mixins": [
    "bettervanillaf3.mixins.json",
    {
      "config": "bettervanillaf3.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": "${fabric_loader}",
    "minecraft": "${minecraft}",
    "yet_another_config_lib_v3": "${yacl}"
  },
  "recommends": {
    "modmenu": "${modmenu}"
  }
}
